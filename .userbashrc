# default HPC bash profile
module load conda git rust cmake/4.0.0

# currently we only have uv here?
source "/hpc/tstapps/tsquant/bin/env"


# move to UK timezone
export TZ=GB

LS_COLORS='rs=0:di=01;34:ln=01;36:mh=00:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:su=37;41:sg=30;43:ca=30;41:tw=30;42:ow=34;42:st=37;44:ex=01;32:*.tar=01;31:*.tgz=01;31:*.arc=01;31:*.arj=01;31:*.taz=01;31:*.lha=01;31:*.lz4=01;31:*.lzh=01;31:*.lzma=01;31:*.tlz=01;31:*.txz=01;31:*.tzo=01;31:*.t7z=01;31:*.zip=01;31:*.z=01;31:*.Z=01;31:*.dz=01;31:*.gz=01;31:*.lrz=01;31:*.lz=01;31:*.lzo=01;31:*.xz=01;31:*.bz2=01;31:*.bz=01;31:*.tbz=01;31:*.tbz2=01;31:*.tz=01;31:*.deb=01;31:*.rpm=01;31:*.jar=01;31:*.war=01;31:*.ear=01;31:*.sar=01;31:*.rar=01;31:*.alz=01;31:*.ace=01;31:*.zoo=01;31:*.cpio=01;31:*.7z=01;31:*.rz=01;31:*.cab=01;31:*.jpg=01;35:*.jpeg=01;35:*.gif=01;35:*.bmp=01;35:*.pbm=01;35:*.pgm=01;35:*.ppm=01;35:*.tga=01;35:*.xbm=01;35:*.xpm=01;35:*.tif=01;35:*.tiff=01;35:*.png=01;35:*.svg=01;35:*.svgz=01;35:*.mng=01;35:*.pcx=01;35:*.mov=01;35:*.mpg=01;35:*.mpeg=01;35:*.m2v=01;35:*.mkv=01;35:*.webm=01;35:*.ogm=01;35:*.mp4=01;35:*.m4v=01;35:*.mp4v=01;35:*.vob=01;35:*.qt=01;35:*.nuv=01;35:*.wmv=01;35:*.asf=01;35:*.rm=01;35:*.rmvb=01;35:*.flc=01;35:*.avi=01;35:*.fli=01;35:*.flv=01;35:*.gl=01;35:*.dl=01;35:*.xcf=01;35:*.xwd=01;35:*.yuv=01;35:*.cgm=01;35:*.emf=01;35:*.axv=01;35:*.anx=01;35:*.ogv=01;35:*.ogx=01;35:*.aac=00;36:*.au=00;36:*.flac=00;36:*.mid=00;36:*.midi=00;36:*.mka=00;36:*.mp3=00;36:*.mpc=00;36:*.ogg=00;36:*.ra=00;36:*.wav=00;36:*.axa=00;36:*.oga=00;36:*.spx=00;36:*.xspf=00;36:';
export LS_COLORS

export PS_FORMAT="pid,ppid,%cpu,command"
alias myps="ps -u ${USER}"

# stop pytracking from here
export PYTRACK_DISABLE=1

# cd to home folders more easily
export CDPATH=.:${HOME}:${HPCSCRATCHDIR}:/lustre01/vol0/${USER}


# move the .vscode-cli data somewhere persistent as it contains the login tokens
export VSCODE_CLI_DATA_DIR="${HPCSCRATCHDIR}/.vscode-cli"

# move the actual .vscode server installs to the local disk
export VSCODE_AGENT_FOLDER=/data1/${USER}/.vscode-server

# store the keychain in .vscode-cli/token.json so it can be shared, and don't
# encrypt it so that other hosts can use the same key
export VSCODE_CLI_USE_FILE_KEYCHAIN=1
export VSCODE_CLI_DISABLE_KEYCHAIN_ENCRYPT=1

# PAT for experiments with build agents
export VSTS_AGENT_INPUT_AUTH=pat

# XDG_CACHE_HOME is already set on HPC, but XDG_DATA_HOME is not, and UV will place
# python interpreters there
export XDG_BIN_HOME=${HPCSCRATCHDIR}/.local/bin
export XDG_DATA_HOME=${HPCSCRATCHDIR}/.local/share
mkdir --parents ${XDG_DATA_HOME} 2>&1 >/dev/null
export PATH=${XDG_BIN_HOME}:${PATH}

# add any cargo builds
export PATH=${HPCSCRATCHDIR}/cargo/bin:${PATH}

# move RUFF_CACHE to local? do we want this?
export RUFF_CACHE_DIR=/data1/${USER}/.ruff_cache

# stop cmake from flooding CPU on shared nodes unless we are on the cluster
export CMAKE_BUILD_PARALLEL_LEVEL=${SLURM_CPUS_ON_NODE:-16}
export CTEST_PARALLEL_LEVEL=${SLURM_CPUS_ON_NODE:-16}

export SALLOC_PARTITION=cascadelake-misc
export SALLOC_ACCOUNT=tai-lng

# export SBATCH_PARTITION=cascadelake
export SBATCH_ACCOUNT=tai-lng
export SBATCH_OUTPUT=${HPCSCRATCHDIR}/log/%x-%j-%N.log

export PYTEST_XDIST_AUTO_NUM_WORKERS=${SLURM_CPUS_ON_NODE:-16}
export TOX_TESTENV_PASSENV="PYTEST_*"

export SQUEUE_FORMAT="%.10i %.16P %32j %8u %8T %10M %16S %16e %16L %.6D %R"

alias cdw="cd \$(realpath ~/workspace)"
alias cdg="cd \$(git rev-parse --show-toplevel)"
alias l='ls -lshA --color=always $@'
alias ppe='python3 -c "import os; [ print(f\"{key:>48s} = {value!r}\") for key, value in sorted(os.environ.items()) ]"'

alias code-tunnel-background="nohup code tunnel > code-tunnel.log &"
alias getcode="curl -L -o - --fail 'https://code.visualstudio.com/sha/download?build=stable&os=cli-alpine-x64' | tar zvxf -"

alias myresources='slurm_resources -u $USER -A "${SBATCH_ACCOUNT}" -p allcpu'
alias myjobs="squeue -u ${USER}"
alias sidle="sinfo --format '%32R %8D %16A' | (sed -u 1q; sort -t '/' -k 2rn)"
alias sidlep="sinfo --format '%32R %8D %16A %16i' | (sed -u 1q; sort -t '/' -k 2rn)"
alias sbusy="squeue -h -t pending -r -O partition | uniq -c | sort -k 1rn"

alias lazygit="/hpcscratch/0066tm/pyhpc/conda/x86_64/envs/lazygit/bin/lazygit"

alias rmtox="fd --max-depth 2 --type d --unrestricted '\.tox' --exec rm -Rf {}"
alias rmvenv="fd --max-depth 2 --type d --unrestricted '\.venv' --exec echo rm -Rf {}"

# NOTE vscode will use /bin/sh on first access so this sets the environment
#      for it's commands. terminals will launch bashrc etc.

TTY=`tty|awk -F/ '{print $2}'`
if [ "$TTY" = "dev" ] ; then
    source <(starship init bash --print-full-init)
fi



